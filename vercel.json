{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "git lfs install --local && git lfs pull && pnpm --filter @boardgames/web... build",
  "installCommand": "pnpm install --frozen-lockfile --filter @boardgames/web... --ignore-scripts",
  "outputDirectory": "packages/web/dist",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://boardgamesserver-production.up.railway.app/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
