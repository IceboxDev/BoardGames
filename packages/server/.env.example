# Server
PORT=3001

# Database — libsql URL from `turso db show <name> --url`. Required.
TURSO_DATABASE_URL=
# Auth token from `turso db tokens create <name>`. Required.
TURSO_AUTH_TOKEN=

# Better Auth
# Generate a fresh secret with: openssl rand -hex 32
BETTER_AUTH_SECRET=replace-me-with-openssl-rand-hex-32
BETTER_AUTH_URL=http://localhost:3001

# Admin bootstrap — first user signing up with this email is auto-promoted
ADMIN_EMAIL=mantas_kandratavicius@yahoo.com

# Google OAuth (optional). Register an OAuth client at
# https://console.cloud.google.com/apis/credentials with redirect URI
# http://localhost:3001/api/auth/callback/google
# Leave both empty to hide the "Continue with Google" button.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Production-only: web origin allowed by CORS + Better Auth trustedOrigins
# Set on Railway (and similar) to your Vercel URL.
WEB_ORIGIN=

# Note: BGG metadata is fetched at dev time via `pnpm fetch-bgg` and committed
# as `bgg.json` per game folder. No token needed at runtime.
