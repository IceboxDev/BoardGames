{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "pnpm --filter @boardgames/server build",
    "watchPatterns": [
      "packages/server/**",
      "packages/core/**",
      "package.json",
      "pnpm-lock.yaml",
      "pnpm-workspace.yaml",
      "railway.json"
    ]
  },
  "deploy": {
    "startCommand": "node packages/server/dist/migrations/cli.js && node packages/server/dist/index.js",
    "healthcheckPath": "/api/health",
    "healthcheckTimeout": 30,
    "restartPolicyType": "ON_FAILURE"
  }
}
