{
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "pnpm --filter @boardgames/web dev",
    "dev:all": "concurrently --names server,web --prefix-colors blue,green \"pnpm --filter @boardgames/server dev\" \"pnpm --filter @boardgames/web dev\"",
    "build": "pnpm -r build",
    "lint": "biome check packages/",
    "lint:fix": "biome check --write packages/",
    "format": "biome format --write packages/",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.8",
    "concurrently": "^9.0.0",
    "lefthook": "^2.1.4",
    "tsx": "^4.21.0",
    "typescript": "~5.7.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "lefthook"
    ]
  }
}
