{
  "private": true,
  "engines": {
    "node": "24.x"
  },
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "pnpm --filter @boardgames/web dev",
    "dev:all": "concurrently --names server,web --prefix-colors blue,green \"$npm_execpath --filter @boardgames/server dev\" \"$npm_execpath --filter @boardgames/web dev\"",
    "build": "pnpm -r build",
    "extract-accents": "node scripts/extract-accents.mjs",
    "bgg-sync": "node --env-file=packages/server/.env scripts/bgg-sync.mjs",
    "gen-descriptions": "node --env-file=packages/server/.env scripts/gen-descriptions/index.mjs",
    "prebuild": "pnpm extract-accents",
    "lint": "biome check packages/ && node scripts/lint-styles.mjs",
    "lint:styles": "node scripts/lint-styles.mjs",
    "lint:styles:baseline": "node scripts/lint-styles.mjs --check-baseline",
    "lint:fix": "biome check --write packages/",
    "format": "biome format --write packages/",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r --parallel --filter './packages/*' test"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.8",
    "@libsql/client": "^0.17.3",
    "concurrently": "^9.0.0",
    "fast-xml-parser": "^5.7.2",
    "lefthook": "^2.1.4",
    "node-vibrant": "^4.0.4",
    "openai": "^4.85.0",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "typescript": "~5.7.0",
    "vitest": "^4.1.5",
    "zod": "^4.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "lefthook",
      "sharp"
    ],
    "overrides": {
      "zod": "^4"
    }
  }
}
